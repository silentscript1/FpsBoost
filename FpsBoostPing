    toggleBtn.Position = UDim2.new(0, 0, 0, 28)
    toggleBtn.BackgroundColor3 = BoostActive and Colors.RedBright or Colors.RedDark
    toggleBtn.BorderSizePixel = 0
    toggleBtn.Text = BoostActive and "DISABLE FPS BOOST" or "ENABLE FPS BOOST"
    toggleBtn.TextColor3 = Colors.White
    toggleBtn.Font = Enum.Font.GothamBold
    toggleBtn.TextSize = 11
    Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 7)
    
    local toggleGlow = Instance.new("UIStroke", toggleBtn)
    toggleGlow.Thickness = 4
    toggleGlow.Color = Colors.RedGlow
    toggleGlow.Transparency = 0.3
    
    -- Hover effect
    local function addHover(btn, hoverColor)
        local original = btn.BackgroundColor3
        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = hoverColor}):Play()
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = original}):Play()
        end)
    end
    addHover(toggleBtn, Colors.RedBright)
    addHover(closeBtn, Colors.RedBright)
    
    -- Entry animation
    panel.Size = UDim2.new(0, 0, 0, 0)
    panel.BackgroundTransparency = 1
    panelGlow.Transparency = 1
    TweenService:Create(panel, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 220, 0, 120),
        BackgroundTransparency = 0
    }):Play()
    TweenService:Create(panelGlow, TweenInfo.new(0.5), {Transparency = 0.35}):Play()
    
    -- Dragging functionality
    local dragging = false
    local dragStart, startPos
    
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = panel.Position
        end
    end)
    
    titleBar.InputEnded:Connect(function()
        dragging = false
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
           input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            panel.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, 
                                       startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    return screenGui, panel, statusText, toggleBtn, closeBtn
end

